<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
        <title>Recipe Finder | Recipe</title>
        <link rel="stylesheet" href="/css/homePageStyle.css">
        <link rel="stylesheet" href="/css/recipeDetailStyle.css">
</head>

<body>
    <%- include("partials/navbar.ejs") %>
        <% if (successMessage) { %>
            <div id="toastMessage">
                <%= successMessage %>
            </div>
            <script>
                //hide the toast message after 3 seconds
                setTimeout(() => {
                    document.querySelector("#toastMessage").style.display = "none";
                }, 3000);
            </script>
            <% } %>

                <div class="recipe">

                    <h1>
                        <%= meal.recipe_name %>
                    </h1>

                    <img style="height: 200px;" src="<%= meal.image_url %>">

                    <h2>Area / Country</h2>
                    <p>
                        <%= meal.area %>
                    </p>

                    <h2>Ingredients</h2>
                    <ul>
                        <% for (let ingredient of ingredients) { %>
                            <li>
                                <%= ingredient.measure %>
                                    <%= ingredient.name %>
                            </li>
                            <% } %>
                    </ul>

                    <h2>Instructions</h2>
                    <p>
                        <%= meal.instructions %>
                    </p>

                    <form action="/updateRecipe" method="GET">
                        <input type="hidden" name="id" value="<%= meal.recipe_id %>">
                        <button type="submit">Update Recipe</button>
                    </form>
                </div>
</body>

</html>
