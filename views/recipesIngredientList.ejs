<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Recipes</title>
</head>
<body>
    <% if(errorMessage!=false) {%>
        <div class="errorMessage">
            <h1> <%= errorMessage %> </h1>
        </div>
    <% } else {%>
        <div>
            <% for( let meal of meals ) { %> 
                <h1> <%= meal.recipe_name %> </h1>
                <img style="height: 100px;" src="<%= meal.image_url %>">

                <% let instructions = meal.instructions || ""; %>
                <% if(instructions.length>200){ %>
                    <p>
                        <%=instructions.slice(0,200)%> ...
                    </p>
                <% } else {%>
                    <p>
                        <%=instructions%>
                    </p>
                <% } %>

                <a href="/recipeDetail?id=<%= meal.recipe_id %>">
                     <button> View Recipe </button>
                </a>
                <hr>
            <% } %>
        </div>
    <% } %>
</body>
</html>
