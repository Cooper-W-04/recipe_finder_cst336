<header class="topbar">
    <div>
        <img src="/img/logo.png" alt="" class="logo">
    </div>

    <nav class="navLinks">
        <a href="/home">Home</a>
        <a href="/addRecipe">Add Recipes</a>
    </nav>

    <div class="topbarRight">
        <form id="navBarSearchForm" action="/getRecipeByIngredient" method="GET" onsubmit="return validateForm()">
            <input type="text" class="searchBox" name="ingredient">
            <button class="searchBtn"><i class="bi bi-search"></i></button>
        </form>

        <script>
            function validateForm() {
                let ingredient = document.forms["navBarSearchForm"]["ingredient"].value.trim();
                console.log(ingredient.length)
                if (ingredient.length < 3) {
                    alert("Please enter 3 or more characters!");
                    return false;
                }
                return true;
            }
        </script>

        <div class="profile">
            <span>Hello, <%= username %>!</span>
            <i class="bi bi-person-circle profileImg"></i>
            <form action="/logout" method="GET">
                <button class="logOutBtn">Log Out</button>
            </form>
        </div>
    </div>
</header>